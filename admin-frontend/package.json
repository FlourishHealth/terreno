{
  "dependencies": {
    "@terreno/ui": "workspace:*",
    "expo-router": "catalog:",
    "jspdf": "^4.2.0",
    "lodash": "catalog:",
    "luxon": "catalog:",
    "react-native": "catalog:"
  },
  "description": "Admin panel frontend screens for @terreno/api backends",
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "@reduxjs/toolkit": "catalog:",
    "@types/lodash": "catalog:",
    "@types/luxon": "catalog:",
    "@types/react": "catalog:",
    "react": "catalog:",
    "react-redux": "catalog:",
    "typescript": "catalog:"
  },
  "files": [
    "dist/**/*",
    "src/**/*"
  ],
  "license": "Apache-2.0",
  "main": "dist/index.js",
  "name": "@terreno/admin-frontend",
  "peerDependencies": {
    "@reduxjs/toolkit": "catalog:",
    "react": "catalog:",
    "react-native-webview": "catalog:",
    "react-redux": "catalog:"
  },
  "peerDependenciesMeta": {
    "react-native-webview": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "compile": "tsc",
    "compile:watch": "tsc -w",
    "dev": "tsc -w",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "lint:unsafefix": "biome check --write --unsafe .",
    "test": "bun test && for f in ./src/isolated/*.isolated.tsx ./src/isolated/*.isolated.ts; do bun test \"$f\" || exit 1; done",
    "test:ci": "bun run test"
  },
  "types": "dist/index.d.ts",
  "version": "0.10.0"
}
