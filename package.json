    "qs": "^6.14.1",
    "router": "^2.2.0",
    "semver": "^7.5.2",
    "tar": "^7.5.3"
  },
  "private": true,
  "scripts": {
    "bootstrap": "bun install && bun run compile",
    "bootstrap:update": "bun install && bun run compile",
    "admin-backend:compile": "bun run --filter '@terreno/admin-backend' compile",
    "admin-backend:lint": "bun run --filter '@terreno/admin-backend' lint",
    "admin-backend:test": "bun run --filter '@terreno/admin-backend' test",
    "admin-frontend:compile": "bun run --filter '@terreno/admin-frontend' compile",
    "admin-frontend:lint": "bun run --filter '@terreno/admin-frontend' lint",
    "ai:compile": "bun run --filter '@terreno/ai' compile",
    "ai:lint": "bun run --filter '@terreno/ai' lint",
    "ai:test": "bun run --filter '@terreno/ai' test",
    "api-health:compile": "bun run --filter '@terreno/api-health' compile",
    "api-health:lint": "bun run --filter '@terreno/api-health' lint",
    "api-health:test": "bun run --filter '@terreno/api-health' test",
    "api:compile": "bun run --filter '@terreno/api' compile",
    "api:lint": "bun run --filter '@terreno/api' lint",
    "api:test": "bun run --filter '@terreno/api' test",
    "backend:dev": "bun run --filter '@terreno/example-backend' dev",
    "backend:lint": "bun run --filter '@terreno/example-backend' lint",
    "backend:seed": "bun run --filter '@terreno/example-backend' seed",
    "compile": "bun run --filter '@terreno/api' compile && bun run --filter '*' compile",
    "compile:watch": "bun run --parallel --filter '*' --if-present compile:watch",
    "demo:android": "bun run --filter 'terreno-demo' android",
    "demo:compile": "bun run --filter 'terreno-demo' compile",
    "demo:eas:android": "bun run --filter 'terreno-demo' eas:android",
    "demo:eas:ios": "bun run --filter 'terreno-demo' eas:ios",
    "demo:eas:ios-sim": "bun run --filter 'terreno-demo' eas:ios-sim",
    "demo:ios": "bun run --filter 'terreno-demo' ios",
    "demo:lint": "bun run --filter 'terreno-demo' lint",
    "demo:start": "bun run --filter 'terreno-demo' start",
    "demo:web": "bun run --filter 'terreno-demo' web",
    "feature-flags:compile": "bun run --filter '@terreno/feature-flags' compile",
    "feature-flags:lint": "bun run --filter '@terreno/feature-flags' lint",
    "feature-flags:test": "bun run --filter '@terreno/feature-flags' test",
    "frontend:android": "bun run --filter '@terreno/example-frontend' android",
    "frontend:ios": "bun run --filter '@terreno/example-frontend' ios",
    "frontend:lint": "bun run --filter '@terreno/example-frontend' lint",
    "frontend:web": "bun run --filter '@terreno/example-frontend' web",
    "lint": "bun run --filter '*' lint",
    "lint:fix": "bun run --filter '*' lint:fix",
    "lint:unsafefix": "bun run --filter '*' lint:unsafefix",
    "maestro:login": "maestro test .maestro/flows/login.yaml",
    "maestro:signup": "maestro test .maestro/flows/signup.yaml",
    "maestro:test": "maestro test .maestro/flows/",
    "mcp:build": "bun run --filter '@terreno/mcp-server' build",
    "mcp:dev": "bun run --filter '@terreno/mcp-server' dev",
    "mcp:lint": "bun run --filter '@terreno/mcp-server' lint",
    "mcp:start": "bun run --filter '@terreno/mcp-server' start",
    "rtk:compile": "bun run --filter '@terreno/rtk' compile",
    "rtk:dev": "bun run --filter '@terreno/rtk' dev",
    "rtk:lint": "bun run --filter '@terreno/rtk' lint",
    "rtk:test": "bun run --filter '@terreno/rtk' test:ci",
    "rtk:web": "bun run --filter '@terreno/rtk' web",
    "rules": "bunx rulesync generate",
    "rules:check": "bunx rulesync generate && git diff --exit-code",
    "test": "bun run --filter '*' test:ci",
    "ui:compile": "bun run --filter '@terreno/ui' compile",
    "ui:dev": "bun run --filter '@terreno/ui' dev",
    "ui:lint": "bun run --filter '@terreno/ui' lint",
    "ui:test": "bun run --filter '@terreno/ui' test:ci",
    "ui:web": "bun run --filter '@terreno/ui' web"
  },
  "version": "1.0.0",
  "workspaces": [
    "admin-backend",
    "admin-frontend",
    "ai",
    "api",
    "api-health",
    "demo",
    "example-backend",
    "example-frontend",
    "feature-flags",
    "mcp-server",
    "rtk",
    "ui"
