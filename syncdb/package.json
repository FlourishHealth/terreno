{
  "dependencies": {
    "luxon": "catalog:",
    "socket.io-client": "catalog:",
    "tinybase": "^8.5.0"
  },
  "description": "Local-first data layer for @terreno apps: TinyBase MergeableStore, durable outbox, websocket delta sync, encrypted web persistence",
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "@testing-library/react-native": "catalog:",
    "@types/bun": "catalog:",
    "@types/luxon": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "expo-sqlite": "~15.2.14",
    "fake-indexeddb": "^6.0.0",
    "react": "catalog:",
    "react-test-renderer": "catalog:",
    "socket.io": "catalog:",
    "typescript": "catalog:"
  },
  "exports": {
    ".": {
      "default": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./react": {
      "default": "./dist/react/index.js",
      "types": "./dist/react/index.d.ts"
    }
  },
  "files": [
    "dist/**/*",
    "src/**/*"
  ],
  "license": "Apache-2.0",
  "main": "dist/index.js",
  "name": "@terreno/syncdb",
  "peerDependencies": {
    "expo-sqlite": "*",
    "react": "catalog:"
  },
  "peerDependenciesMeta": {
    "expo-sqlite": {
      "optional": true
    },
    "react": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "compile": "tsc",
    "compile:watch": "tsc -w",
    "dev": "tsc -w",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "lint:unsafefix": "biome check --write --unsafe .",
    "test": "bun test",
    "test:ci": "bun test",
    "test:coverage": "bun run ../scripts/check-coverage.ts"
  },
  "types": "dist/index.d.ts",
  "version": "0.23.1"
}
