{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "ignoreDeprecations": "6.0",
    "paths": {
      "@stories": ["stories"],
      "@components": ["components"],
      "@config": ["demoConfig"],
      "@contexts/*": ["contexts/*"],
      "@story-config": ["story-config"]
    },
    "jsx": "react-jsx"
  },
  "exclude": ["**/*.test.ts", "**/*.test.tsx", "appium/**"]
}

