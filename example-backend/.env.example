# Example backend environment variables
# Copy to .env and adjust for local development.

# MongoDB (replica set required for realtime/sync change streams)
MONGO_URI=mongodb://127.0.0.1:27017/terreno-example?replicaSet=rs0

# Authentication (Better Auth is the default for the example app)
AUTH_PROVIDER=better-auth
BETTER_AUTH_SECRET=terreno-example-better-auth-secret-dev-only-32
BETTER_AUTH_URL=http://localhost:4000

# Legacy JWT secrets (still required for RealtimeApp socket JWT fallback)
TOKEN_SECRET=dev-token-secret
TOKEN_ISSUER=terreno-dev
REFRESH_TOKEN_SECRET=dev-refresh-secret
SESSION_SECRET=dev-session-secret

# Server
PORT=4000

# Extra web origins allowed for credentialed CORS (comma-separated). The dev frontend
# origin http://localhost:8082 is allowed by default; set this to your hosted frontend
# origin(s) in deployed environments (Better Auth uses credentialed cross-origin requests).
# CORS_ORIGINS=https://your-frontend.example.com

# Optional: enable the standalone admin SPA at /console
# ADMIN_SPA_ENABLED=true

# Optional: social OAuth providers
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# APPLE_CLIENT_ID=
# APPLE_CLIENT_SECRET=
