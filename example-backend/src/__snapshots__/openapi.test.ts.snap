    "/admin/feature-flags/": {
      "get": {
        "parameters": [
          {
            "in": "query",
            "name": "_id",
            "schema": {
              "properties": {
                "$in": {
                  "items": {
                    "type": "string",
                  },
                  "type": "array",
                },
              },
              "type": "object",
            },
          },
          {
            "in": "query",
            "name": "page",
            "schema": {
              "type": "number",
            },
          },
          {
            "in": "query",
            "name": "sort",
            "schema": {
              "type": "string",
            },
          },
          {
            "in": "query",
            "name": "limit",
            "schema": {
              "type": "number",
            },
          },
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "data": {
                      "items": {
                        "properties": {
                          "_id": {
                            "type": "string",
                          },
                          "archived": {
                            "description": "Archived flags are excluded from evaluation. Use this instead of deleting flags to prevent bloat as new features are added.",
                            "type": "boolean",
                          },
                          "created": {
                            "description": "When this document was created",
                            "format": "date-time",
                            "type": "string",
                          },
                          "deleted": {
                            "description": "Deleted objects are not returned in any find() or findOne() by default. Add {deleted: true} to find them.",
                            "type": "boolean",
                          },
                          "description": {
                            "description": "Explanation of what this flag controls",
                            "type": "string",
                          },
                          "enabled": {
                            "description": "Global kill switch — if false, flag is off for everyone",
                            "type": "boolean",
                          },
                          "key": {
                            "description": "Unique identifier for the flag, e.g., 'new-checkout-flow'",
                            "type": "string",
                          },
                          "name": {
                            "description": "Human-readable display name",
                            "type": "string",
                          },
                          "rolloutPercentage": {
                            "description": "For boolean flags with no matching rules: percentage of users who get true",
                            "type": "number",
                          },
                          "rules": {
                            "items": {
                              "properties": {
                                "enabled": {
                                  "description": "Whether the flag/variant is turned on when this rule matches. For boolean flags this is the override value; for variant flags it gates whether the forced variant applies.",
                                  "type": "boolean",
                                },
                                "field": {
                                  "description": "User field to match against (use with operator + value). Supports dot notation, e.g., 'email', 'admin', 'address.zip'. Use field/operator/value together, OR segment alone.",
                                  "type": "string",
                                },
                                "operator": {
                                  "description": "Comparison operator for field-based rules (use with field + value). Use field/operator/value together, OR segment alone.",
                                  "enum": [
                                    "eq",
                                    "neq",
                                    "in",
                                    "nin",
                                    "gt",
                                    "lt",
                                    "contains",
                                  ],
                                  "type": "string",
                                },
                                "segment": {
                                  "description": "Name of a registered segment function, e.g., 'pro-users'. Use segment alone, OR field/operator/value together.",
                                  "type": "string",
                                },
                                "value": {
                                  "description": "Value to compare against (use with field + operator). String, number, boolean, or array for in/nin. Use field/operator/value together, OR segment alone.",
                                },
                                "variant": {
                                  "description": "For variant flags only: forced variant key when this rule matches. Use field/operator/value together, OR segment alone.",
                                  "type": "string",
                                },
                              },
                              "required": [],
                              "type": "object",
                            },
                            "type": "array",
                          },
                          "type": {
                            "description": "Boolean toggle or multi-variant A/B test",
                            "enum": [
                              "boolean",
                              "variant",
                            ],
                            "type": "string",
                          },
                          "updated": {
                            "description": "When this document was last updated",
                            "format": "date-time",
                            "type": "string",
                          },
                          "variants": {
                            "items": {
                              "properties": {
                                "key": {
                                  "description": "Variant identifier, e.g., 'control', 'variant-a'",
                                  "type": "string",
                                },
                                "weight": {
                                  "description": "Percentage weight for assignment (0-100, all must sum to 100)",
                                  "type": "number",
                                },
                              },
                              "required": [
                                "key",
                                "weight",
                              ],
                              "type": "object",
                            },
                            "type": "array",
                          },
                        },
                        "required": [
                          "key",
                          "name",
                          "_id",
                          "created",
                          "updated",
                        ],
                        "type": "object",
                      },
                      "type": "array",
                    },
                    "limit": {
                      "type": "number",
                    },
                    "more": {
                      "type": "boolean",
                    },
                    "page": {
                      "type": "number",
                    },
                    "total": {
                      "type": "number",
                    },
                  },
                  "type": "object",
                },
              },
            },
            "description": "Successful list",
          },
          "400": {
            "content": {
              "application/json": {
                "schema": {
