    "/admin/consent-responses/": {
      "get": {
        "parameters": [
          {
            "in": "query",
            "name": "_id",
            "schema": {
              "properties": {
                "$in": {
                  "items": {
                    "type": "string",
                  },
                  "type": "array",
                },
              },
              "type": "object",
            },
          },
          {
            "in": "query",
            "name": "userId",
            "schema": {
              "oneOf": [
                {
                  "description": "Reference to the User who submitted this response",
                  "type": "schemaobjectid",
                },
                {
                  "properties": {
                    "$in": {
                      "items": {
                        "type": "schemaobjectid",
                      },
                      "type": "array",
                    },
                  },
                  "type": "object",
                },
              ],
            },
          },
          {
            "in": "query",
            "name": "agreed",
            "schema": {
              "oneOf": [
                {
                  "description": "Whether the user agreed (true) or declined (false) the consent form",
                  "type": "boolean",
                },
                {
                  "properties": {
                    "$in": {
                      "items": {
                        "type": "boolean",
                      },
                      "type": "array",
                    },
                  },
                  "type": "object",
                },
              ],
            },
          },
          {
            "in": "query",
            "name": "locale",
            "schema": {
              "oneOf": [
                {
                  "description": "Locale code of the content version the user viewed when responding",
                  "type": "string",
                },
                {
                  "properties": {
                    "$in": {
                      "items": {
                        "type": "string",
                      },
                      "type": "array",
                    },
                  },
                  "type": "object",
                },
              ],
            },
          },
          {
            "in": "query",
            "name": "agreedAt",
            "schema": {
              "oneOf": [
                {
                  "description": "Timestamp when the user submitted their agreement or declination",
                  "format": "date-time",
                  "type": "string",
                },
                {
                  "properties": {
                    "$gt": {
                      "description": "Timestamp when the user submitted their agreement or declination",
                      "format": "date-time",
                      "type": "string",
                    },
                    "$gte": {
                      "description": "Timestamp when the user submitted their agreement or declination",
                      "format": "date-time",
                      "type": "string",
                    },
                    "$lt": {
                      "description": "Timestamp when the user submitted their agreement or declination",
                      "format": "date-time",
                      "type": "string",
                    },
                    "$lte": {
                      "description": "Timestamp when the user submitted their agreement or declination",
                      "format": "date-time",
                      "type": "string",
                    },
                  },
                  "type": "object",
                },
              ],
            },
          },
          {
            "in": "query",
            "name": "page",
            "schema": {
              "type": "number",
            },
          },
          {
            "in": "query",
            "name": "sort",
            "schema": {
              "type": "string",
            },
          },
          {
            "in": "query",
            "name": "limit",
            "schema": {
              "type": "number",
            },
          },
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "data": {
                      "items": {
                        "properties": {
                          "_id": {
                            "type": "string",
                          },
                          "agreed": {
                            "description": "Whether the user agreed (true) or declined (false) the consent form",
                            "type": "boolean",
                          },
                          "agreedAt": {
                            "description": "Timestamp when the user submitted their agreement or declination",
                            "format": "date-time",
                            "type": "string",
                          },
                          "checkboxValues": {
                            "additionalProperties": {
                              "type": "boolean",
                            },
                            "description": "Map of checkbox index to boolean indicating whether each checkbox was checked",
                            "type": "object",
                          },
                          "consentFormId": {
                            "properties": {
                              "slug": {
                                "description": "URL-safe identifier for this form, combined with version to uniquely identify a form",
                                "type": "string",
                              },
                              "title": {
                                "description": "Human-readable title of the consent form",
                                "type": "string",
                              },
                              "type": {
                                "description": "Category of consent form",
                                "enum": [
                                  "agreement",
                                  "privacy",
                                  "hipaa",
                                  "research",
                                  "terms",
                                  "custom",
                                ],
                                "type": "string",
                              },
                              "version": {
                                "default": 1,
                                "description": "Version number of this form. Incrementing the version requires users to re-consent",
                                "type": "number",
                              },
                            },
                            "type": "object",
                          },
                          "contentSnapshot": {
                            "description": "Snapshot of the form content in the user's locale at the time of response",
                            "type": "string",
                          },
                          "created": {
                            "description": "When this document was created",
                            "format": "date-time",
                            "type": "string",
                          },
                          "deleted": {
                            "description": "Deleted objects are not returned in any find() or findOne() by default. Add {deleted: true} to find them.",
                            "type": "boolean",
                          },
                          "formVersionSnapshot": {
                            "description": "Version number of the form at the time the user responded",
                            "type": "number",
                          },
                          "ipAddress": {
                            "description": "IP address of the user at the time of response, captured for audit purposes",
                            "type": "string",
                          },
                          "locale": {
                            "description": "Locale code of the content version the user viewed when responding",
                            "type": "string",
                          },
                          "signature": {
                            "description": "Base64-encoded signature image or typed signature text, if captured",
                            "type": "string",
                          },
                          "signedAt": {
                            "description": "Timestamp when the user provided their signature",
                            "format": "date-time",
                            "type": "string",
                          },
                          "updated": {
                            "description": "When this document was last updated",
                            "format": "date-time",
                            "type": "string",
                          },
                          "userAgent": {
                            "description": "User-agent string of the browser or app used to submit the response",
                            "type": "string",
                          },
                          "userId": {
                            "properties": {
                              "email": {
                                "description": "The user's email address, used for authentication",
                                "type": "string",
                              },
                              "name": {
                                "description": "The user's display name",
                                "type": "string",
                              },
                            },
                            "type": "object",
                          },
                        },
                        "required": [
                          "agreed",
                          "agreedAt",
                          "consentFormId",
                          "locale",
                          "userId",
                          "_id",
                          "created",
                          "updated",
                        ],
                        "type": "object",
                      },
                      "type": "array",
                    },
                    "limit": {
                      "type": "number",
                    },
                    "more": {
                      "type": "boolean",
                    },
                    "page": {
                      "type": "number",
                    },
                    "total": {
                      "type": "number",
                    },
                  },
                  "type": "object",
                },
              },
            },
            "description": "Successful list",
          },
          "400": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/APIError",
                },
              },
            },
            "description": "Bad request",
          },
