                },
              },
              "type": "object",
            },
          },
          {
            "in": "query",
            "name": "title",
            "schema": {
              "oneOf": [
                {
                  "description": "Human-readable title of the consent form",
                  "type": "string",
                },
                {
                  "properties": {
                    "$in": {
                      "items": {
                        "type": "string",
                      },
                      "type": "array",
                    },
                  },
                  "type": "object",
                },
              ],
            },
          },
          {
            "in": "query",
            "name": "type",
            "schema": {
              "oneOf": [
                {
                  "description": "Category of consent form",
                  "enum": [
                    "agreement",
                    "privacy",
                    "hipaa",
                    "research",
                    "terms",
                    "custom",
                  ],
                  "type": "string",
                },
                {
                  "properties": {
                    "$in": {
                      "items": {
                        "type": "string",
                      },
                      "type": "array",
                    },
                  },
                  "type": "object",
                },
              ],
            },
          },
          {
            "in": "query",
            "name": "version",
            "schema": {
              "oneOf": [
                {
                  "default": 1,
                  "description": "Version number of this form. Incrementing the version requires users to re-consent",
                  "type": "number",
                },
                {
                  "properties": {
                    "$gt": {
                      "default": 1,
                      "description": "Version number of this form. Incrementing the version requires users to re-consent",
                      "type": "number",
                    },
                    "$gte": {
                      "default": 1,
                      "description": "Version number of this form. Incrementing the version requires users to re-consent",
                      "type": "number",
                    },
                    "$lt": {
                      "default": 1,
                      "description": "Version number of this form. Incrementing the version requires users to re-consent",
                      "type": "number",
                    },
                    "$lte": {
                      "default": 1,
                      "description": "Version number of this form. Incrementing the version requires users to re-consent",
                      "type": "number",
                    },
                  },
                  "type": "object",
                },
              ],
            },
          },
          {
            "in": "query",
            "name": "active",
            "schema": {
              "oneOf": [
                {
                  "default": false,
                  "description": "Whether this consent form is currently active and available to users",
                  "type": "boolean",
                },
                {
                  "properties": {
                    "$in": {
                      "items": {
                        "type": "boolean",
                      },
                      "type": "array",
                    },
                  },
                  "type": "object",
                },
              ],
            },
          },
          {
            "in": "query",
            "name": "order",
            "schema": {
              "oneOf": [
                {
                  "default": 0,
                  "description": "Display order relative to other consent forms (lower numbers appear first)",
                  "type": "number",
                },
                {
                  "properties": {
                    "$gt": {
                      "default": 0,
                      "description": "Display order relative to other consent forms (lower numbers appear first)",
