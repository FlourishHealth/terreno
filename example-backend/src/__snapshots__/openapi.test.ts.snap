    "/admin/feature-flags/": {
      "get": {
        "parameters": [
          {
            "in": "query",
            "name": "_id",
            "schema": {
              "properties": {
                "$in": {
                  "items": {
                    "type": "string",
                  },
                  "type": "array",
                },
              },
              "type": "object",
            },
          },
          {
            "in": "query",
            "name": "key",
            "schema": {
              "oneOf": [
                {
                  "description": "Unique identifier for the flag, e.g., 'new-checkout-flow'",
                  "type": "string",
                },
                {
                  "properties": {
                    "$in": {
                      "items": {
                        "type": "string",
                      },
                      "type": "array",
                    },
                  },
                  "type": "object",
                },
              ],
            },
          },
          {
            "in": "query",
            "name": "name",
            "schema": {
              "oneOf": [
                {
                  "description": "Human-readable display name",
                  "type": "string",
                },
                {
                  "properties": {
                    "$in": {
                      "items": {
                        "type": "string",
                      },
                      "type": "array",
                    },
                  },
                  "type": "object",
                },
              ],
            },
          },
          {
            "in": "query",
            "name": "type",
            "schema": {
              "oneOf": [
                {
                  "default": "boolean",
                  "description": "Boolean toggle or multi-variant A/B test",
                  "enum": [
                    "boolean",
                    "variant",
                  ],
                  "type": "string",
                },
                {
                  "properties": {
                    "$in": {
                      "items": {
                        "type": "string",
                      },
                      "type": "array",
                    },
                  },
                  "type": "object",
                },
              ],
            },
          },
          {
            "in": "query",
            "name": "enabled",
            "schema": {
              "oneOf": [
                {
                  "default": false,
                  "description": "Global kill switch — if false, flag is off for everyone",
                  "type": "boolean",
                },
                {
                  "properties": {
                    "$in": {
                      "items": {
                        "type": "boolean",
                      },
                      "type": "array",
                    },
                  },
                  "type": "object",
                },
              ],
            },
          },
          {
            "in": "query",
            "name": "archived",
            "schema": {
              "oneOf": [
                {
                  "default": false,
                  "description": "Archived flags are excluded from evaluation. Use this instead of deleting flags to prevent bloat as new features are added.",
                  "type": "boolean",
                },
                {
                  "properties": {
                    "$in": {
                      "items": {
                        "type": "boolean",
                      },
                      "type": "array",
                    },
                  },
                  "type": "object",
                },
              ],
            },
          },
          {
            "in": "query",
            "name": "defaultVariant",
            "schema": {
              "oneOf": [
                {
                  "description": "OpenFeature defaultVariant key. Returned when the flag is disabled or errors during evaluation. For boolean flags, must be 'on' or 'off'. For variant flags, must be one of the keys in \`variants\`. Auto-populated on save when omitted (boolean → 'off', variant → first variant key).",
                  "required": false,
                  "type": "string",
                },
                {
                  "properties": {
                    "$in": {
                      "items": {
                        "type": "string",
                      },
                      "type": "array",
                    },
                  },
                  "type": "object",
                },
              ],
            },
          },
          {
            "in": "query",
            "name": "created",
            "schema": {
              "oneOf": [
                {
                  "description": "When this document was created",
                  "format": "date-time",
                  "type": "string",
                },
                {
                  "properties": {
                    "$gt": {
                      "description": "When this document was created",
                      "format": "date-time",
                      "type": "string",
                    },
                    "$gte": {
                      "description": "When this document was created",
                      "format": "date-time",
                      "type": "string",
                    },
