    "@reduxjs/toolkit": "catalog:",
    "@sentry/react": "catalog:",
    "@terreno/rtk": "workspace:*",
    "@terreno/ui": "workspace:*",
    "expo": "catalog:",
    "expo-constants": "catalog:",
    "expo-dev-client": "catalog:",
    "expo-font": "catalog:",
    "expo-linking": "catalog:",
    "expo-notifications": "catalog:",
    "expo-router": "catalog:",
    "expo-splash-screen": "catalog:",
    "expo-updates": "catalog:",
    "lodash": "catalog:",
    "luxon": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-native": "catalog:",
    "react-native-gesture-handler": "catalog:",
    "react-native-reanimated": "catalog:",
    "react-native-safe-area-context": "catalog:",
    "react-native-web": "catalog:",
    "react-native-webview": "catalog:",
    "react-native-worklets": "catalog:",
    "react-redux": "catalog:",
    "redux-persist": "catalog:"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "@playwright/test": "^1.58.2",
    "@types/lodash": "catalog:",
    "@types/luxon": "catalog:",
    "@types/react": "catalog:",
    "babel-preset-expo": "catalog:",
    "mongodb": "^6.20.0",
    "typescript": "catalog:"
  },
  "main": "index.js",
  "name": "@terreno/example-frontend",
  "private": true,
  "scripts": {
    "android": "bun expo start --android --port 8082",
    "doctor": "bunx expo-doctor",
    "eas-build-post-install": "cd .. && bun run compile && bun run --filter '@terreno/ui' types",
    "export": "bun expo export --platform web",
    "ios": "bun expo start --ios --port 8082",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "lint:unsafefix": "biome check --write --unsafe .",
    "sdk": "bun scripts/generate-sdk.ts && bun biome check --write scripts/generate-sdk.ts",
    "start": "bun expo start --port 8082",
    "test": "bun test ./**/*.test.ts ./**/*.test.tsx",
    "test:e2e": "playwright test",
    "test:e2e:report": "playwright show-report",
    "web": "bun expo start --web --port 8082"
  },
  "version": "1.0.0"
}
