    "router": "^2.2.0",
    "serve-static": "^1.15.0",
    "swagger-parser": "^10.0.3",
    "swagger-ui-dist": "^5.11.8",
    "yaml": "^2.4.0",
    "axios": "catalog:",
    "better-auth": "catalog:",
    "cors": "^2.8.5",
    "cron": "^4.3.4",
    "expo-server-sdk": "^6.0.0",
